$C = "../Common.ui";

@PageOverlay = Group {
  Background: #050608(0.86);
  LayoutMode: Middle;
};

@SectionTitleStyle = LabelStyle(
  FontSize: 26,
  TextColor: #e7c58d,
  RenderBold: true,
  FontName: "Secondary",
  LetterSpacing: 1
);

@SectionSubtitleStyle = LabelStyle(
  FontSize: 13,
  TextColor: #9f8e74,
  RenderUppercase: true
);

@CardTitleStyle = LabelStyle(
  FontSize: 15,
  TextColor: #d9ae6a,
  RenderBold: true,
  RenderUppercase: true,
  FontName: "Secondary"
);

@KeyStyle = LabelStyle(
  FontSize: 12,
  TextColor: #8d7c65,
  RenderUppercase: true,
  RenderBold: true
);

@ValueStyle = LabelStyle(
  FontSize: 15,
  TextColor: #f1ebe0,
  RenderBold: true,
  Wrap: true
);

@BodyStyle = LabelStyle(
  FontSize: 13,
  TextColor: #d7c9b9,
  Wrap: true
);

@MutedStyle = LabelStyle(
  FontSize: 12,
  TextColor: #8c7d68,
  Wrap: true
);

@MetaStyle = LabelStyle(
  FontSize: 12,
  TextColor: #e0c08a,
  RenderBold: true,
  Wrap: true
);

@BadgeLabelStyle = LabelStyle(
  FontSize: 11,
  TextColor: #a5957d,
  RenderUppercase: true,
  RenderBold: true
);

@BadgeValueStyle = LabelStyle(
  FontSize: 14,
  TextColor: #f6ead3,
  RenderBold: true,
  Wrap: true
);

@ButtonStyle = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
  Sounds: $C.@ButtonSounds,
);

@NavButton = $C.@TextButton {
  Style: @ButtonStyle;
  Anchor: (Height: 42);
  Padding: (Left: 14, Right: 14, Top: 6, Bottom: 6);
};

@NavButtonSelected = $C.@TextButton {
  Style: @ButtonStyle;
  Anchor: (Height: 42);
  Padding: (Left: 14, Right: 14, Top: 6, Bottom: 6);
};

@ActionButton = $C.@TextButton {
  Style: @ButtonStyle;
  Anchor: (Width: 170, Height: 42);
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
};

@WideActionButton = $C.@TextButton {
  Style: @ButtonStyle;
  Anchor: (Width: 200, Height: 42);
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
};

@SmallCard = Group {
  @Width = 160;
  Anchor: (Width: @Width, Height: 58);
  LayoutMode: Top;
  Padding: (Left: 12, Right: 12, Top: 9, Bottom: 9);
  Background: #221915(0.94);
};

@LargeCard = Group {
  LayoutMode: Top;
  Padding: (Full: 16);
  Background: #17120f(0.94);
};

@SectionPanel = Group {
  Anchor: (Full: 0);
  LayoutMode: TopScrolling;
  ScrollbarStyle: $C.@DefaultScrollbarStyle;
  Padding: (Right: 8);
};

@PerkRow = Group {
  LayoutMode: Left;
  Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);
  Background: #18130f(0.88);
  Visible: false;
};

@AbilityCard = Group {
  LayoutMode: Top;
  Padding: (Full: 14);
  Background: #18130f(0.9);
  Anchor: (Bottom: 12);
  Visible: false;
};

@PageOverlay #SpellbookOverlay {
  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 1180, Height: 830);
    Padding: (Full: 0);

    #Title {
      Group {
        LayoutMode: Left;
        Padding: (Left: 18, Right: 18, Top: 7);

        $C.@Title {
          @Alignment = Start;
          @Text = "Mentees Spellbook";
        }
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Full: 0);

      Group #Sidebar {
        Anchor: (Width: 210);
        LayoutMode: Top;
        Padding: (Left: 14, Right: 14, Top: 18, Bottom: 18);
        Background: #100b09;

        Label {
          Style: @CardTitleStyle;
          Text: "Navigate";
          Padding: (Left: 4, Bottom: 10);
        }

        Group #NavOverviewGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavOverviewSelected { Text: "Overview"; Visible: true; }
          @NavButton #NavOverviewButton { Text: "Overview"; Visible: false; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavJourneyGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavJourneySelected { Text: "Journey"; Visible: false; }
          @NavButton #NavJourneyButton { Text: "Journey"; Visible: true; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavGrimoireGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavGrimoireSelected { Text: "Grimoire"; Visible: false; }
          @NavButton #NavGrimoireButton { Text: "Grimoire"; Visible: true; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavPerksGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavPerksSelected { Text: "Perk Web"; Visible: false; }
          @NavButton #NavPerksButton { Text: "Perk Web"; Visible: true; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavResourcesGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavResourcesSelected { Text: "Resources"; Visible: false; }
          @NavButton #NavResourcesButton { Text: "Resources"; Visible: true; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavCodexGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavCodexSelected { Text: "Codex"; Visible: false; }
          @NavButton #NavCodexButton { Text: "Codex"; Visible: true; }
        }

        Group { Anchor: (Height: 6); }

        Group #NavJournalGroup {
          LayoutMode: Top;
          @NavButtonSelected #NavJournalSelected { Text: "Journal"; Visible: false; }
          @NavButton #NavJournalButton { Text: "Journal"; Visible: true; }
        }

        Group { FlexWeight: 1; }

        Label {
          Style: @MutedStyle;
          Text: "Journey chooses class and race. Grimoire chooses style. Perk Web queues and confirms passive perk picks.";
          Padding: (Left: 4, Top: 14);
        }
      }

      Group #MainColumn {
        FlexWeight: 1;
        LayoutMode: Top;
        Padding: (Full: 22);
        Background: #0d0b0a(0.34);

        Group #HeroCard {
          LayoutMode: Top;
          Padding: (Full: 18);
          Background: #1a1410(0.95);

          Label #SectionTitle {
            Style: @SectionTitleStyle;
            Text: "Overview";
          }

          Label #SectionSubtitle {
            Style: @SectionSubtitleStyle;
            Text: "Who you are, what you can do, and what comes next.";
            Padding: (Top: 2, Bottom: 14);
          }

          Group #HeroBadges {
            LayoutMode: Left;

            @SmallCard #HeroClassCard {
              Label { Style: @BadgeLabelStyle; Text: "Class"; }
              Label #HeroClassValue { Style: @BadgeValueStyle; Text: "Unchosen"; }
            }

            Group { Anchor: (Width: 12); }

            @SmallCard #HeroRaceCard {
              Label { Style: @BadgeLabelStyle; Text: "Race"; }
              Label #HeroRaceValue { Style: @BadgeValueStyle; Text: "Unchosen"; }
            }

            Group { Anchor: (Width: 12); }

            @SmallCard #HeroStyleCard {
              Label { Style: @BadgeLabelStyle; Text: "Style"; }
              Label #HeroStyleValue { Style: @BadgeValueStyle; Text: "Unchosen"; }
            }

            Group { Anchor: (Width: 12); }

            @SmallCard #HeroLevelCard {
              Label { Style: @BadgeLabelStyle; Text: "Level"; }
              Label #HeroLevelValue { Style: @BadgeValueStyle; Text: "1 / 200"; }
            }
          }

          Label #HeroProgress {
            Style: @BodyStyle;
            Text: "Lv 1 | XP 0 / 100";
            Padding: (Top: 14, Bottom: 4);
          }

          Label #HeroNextStep {
            Style: @BodyStyle;
            Text: "Next Step: Choose your class.";
          }

          Label #ActionStatus {
            Style: @MutedStyle;
            Text: "Spellbook ready.";
            Padding: (Top: 10);
          }
        }

        Group { Anchor: (Height: 16); }

        Group #SectionViewport {
          FlexWeight: 1;
          LayoutMode: Full;

          @SectionPanel #OverviewPanel {
            LayoutMode: Left;

            @LargeCard #OverviewIdentityCard {
              Label { Style: @CardTitleStyle; Text: "Identity"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Class"; }
              Label #OverviewIdentityClassValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Race"; }
              Label #OverviewIdentityRaceValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Style"; }
              Label #OverviewIdentityStyleValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Level Progress"; }
              Label #OverviewIdentityLevelValue { Style: @BodyStyle; Text: "Lv 1 | XP 0 / 100"; }
            }

            Group { Anchor: (Width: 16); }

            @LargeCard #OverviewPathCard {
              FlexWeight: 1;
              Label { Style: @CardTitleStyle; Text: "Current Path"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Next Step"; }
              Label #OverviewPathNextStepValue { Style: @ValueStyle; Text: "Choose your class."; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Pending Perks"; }
              Label #OverviewPathPendingPerksValue { Style: @BodyStyle; Text: "No"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Active Synergies"; }
              Label #OverviewPathSynergyValue { Style: @BodyStyle; Text: "0"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Resources"; }
              Label #OverviewPathResourceValue { Style: @BodyStyle; Text: "No class resource yet."; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Tip"; }
              Label #OverviewPathTipValue { Style: @MutedStyle; Text: "Use the sidebar to inspect abilities, perks, resources, and lore."; }
            }
          }

          @SectionPanel #JourneyPanel {
            Visible: false;

            @LargeCard #JourneyClassCard {
              Label { Style: @CardTitleStyle; Text: "Class Path"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Class"; }
              Label #JourneyClassValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Theme"; }
              Label #JourneyThemeValue { Style: @BodyStyle; Text: "Choose a class to define your path."; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Element"; }
              Label #JourneyElementValue { Style: @BodyStyle; Text: "Unchosen"; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Passive"; }
              Label #JourneyPassiveNameValue { Style: @ValueStyle; Text: "Unawakened"; Padding: (Bottom: 4); }
              Label #JourneyPassiveDescValue { Style: @BodyStyle; Text: "Your class passive will appear here."; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Choose Class"; }
              Label #JourneyClassActionValue { Style: @MutedStyle; Text: "Choose your class here."; Padding: (Bottom: 10); }
              Group #JourneyClassButtons {
                LayoutMode: Left;
                @ActionButton #ClassTerraButton { Text: "Terra"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #ClassHydroButton { Text: "Hydro"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #ClassAeroButton { Text: "Aero"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #ClassCorruptusButton { Text: "Corruptus"; }
              }
            }

            Group { Anchor: (Height: 14); }

            @LargeCard #JourneyRaceCard {
              Label { Style: @CardTitleStyle; Text: "Race Path"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Race"; }
              Label #JourneyRaceValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Passive"; }
              Label #JourneyRacePassiveValue { Style: @BodyStyle; Text: "Choose a race to gain identity bonuses."; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Special"; }
              Label #JourneyRaceSpecialValue { Style: @BodyStyle; Text: "Race specialties appear here."; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Choose Race"; }
              Label #JourneyRaceActionValue { Style: @MutedStyle; Text: "Choose your race here."; Padding: (Bottom: 10); }
              Group {
                LayoutMode: Left;
                @ActionButton #RaceButton1 { Text: "Race 1"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton2 { Text: "Race 2"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton3 { Text: "Race 3"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton4 { Text: "Race 4"; }
              }
              Group { Anchor: (Height: 8); }
              Group {
                LayoutMode: Left;
                @ActionButton #RaceButton5 { Text: "Race 5"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton6 { Text: "Race 6"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton7 { Text: "Race 7"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton8 { Text: "Race 8"; }
              }
              Group { Anchor: (Height: 8); }
              Group {
                LayoutMode: Left;
                @ActionButton #RaceButton9 { Text: "Race 9"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton10 { Text: "Race 10"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton11 { Text: "Race 11"; }
                Group { Anchor: (Width: 8); }
                @ActionButton #RaceButton12 { Text: "Race 12"; }
              }
            }

            Group { Anchor: (Height: 14); }

            @LargeCard #JourneyProgressCard {
              Label { Style: @CardTitleStyle; Text: "Progression"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Style"; }
              Label #JourneyStyleValue { Style: @ValueStyle; Text: "Unchosen"; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Progress"; }
              Label #JourneyProgressValue { Style: @BodyStyle; Text: "Total XP: 0 | Achievements: 0"; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Milestone"; }
              Label #JourneyMilestoneValue { Style: @BodyStyle; Text: "Next perk tier unlocks at level 10."; Padding: (Bottom: 8); }
              Label { Style: @KeyStyle; Text: "Prompt"; }
              Label #JourneyPromptValue { Style: @BodyStyle; Text: "Choose your class."; }
            }
          }

          @SectionPanel #GrimoirePanel {
            Visible: false;

            Label #GrimoireEmpty {
              Style: @BodyStyle;
              Text: "Choose a class first, then a style, to awaken your grimoire.";
            }

            Group #GrimoireDetails {
              Visible: false;
              LayoutMode: Top;

              Group {
                LayoutMode: Left;

                @SmallCard #GrimoireStyleCard {
                  Label { Style: @BadgeLabelStyle; Text: "Style"; }
                  Label #GrimoireStyleValue { Style: @BadgeValueStyle; Text: "Unchosen"; }
                }

                Group { Anchor: (Width: 12); }

                @SmallCard #GrimoireThemeCard {
                  Label { Style: @BadgeLabelStyle; Text: "Theme"; }
                  Label #GrimoireThemeValue { Style: @BadgeValueStyle; Text: "No theme yet"; }
                }

                Group { Anchor: (Width: 12); }

                @SmallCard #GrimoireResourceCard {
                  Label { Style: @BadgeLabelStyle; Text: "Resource"; }
                  Label #GrimoireResourceValue { Style: @BadgeValueStyle; Text: "No class resource"; }
                }
              }

              Label #GrimoireAbilityRule {
                Style: @MutedStyle;
                Text: "Styles grant all 3 active abilities immediately. Perks modify them later.";
                Padding: (Top: 12, Bottom: 12);
              }

              Label { Style: @KeyStyle; Text: "Choose Style"; }
              Label #GrimoireStyleActionValue { Style: @MutedStyle; Text: "Choose a style here."; Padding: (Bottom: 10); }

              Group #StyleButtonsContainer {
                LayoutMode: Top;

                Group {
                  LayoutMode: Left;
                  @ActionButton #StyleButton1 { Text: "Style 1"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton2 { Text: "Style 2"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton3 { Text: "Style 3"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton4 { Text: "Style 4"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton5 { Text: "Style 5"; }
                }

                Group { Anchor: (Height: 8); }

                Group {
                  LayoutMode: Left;
                  @ActionButton #StyleButton6 { Text: "Style 6"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton7 { Text: "Style 7"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton8 { Text: "Style 8"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton9 { Text: "Style 9"; }
                  Group { Anchor: (Width: 8); }
                  @ActionButton #StyleButton10 { Text: "Style 10"; }
                }
              }

              Group { Anchor: (Height: 12); }

              @AbilityCard #AbilityCard1 {
                Label #Ability1Name { Style: @CardTitleStyle; Text: "Ability One"; }
                Label #Ability1Id { Style: @MutedStyle; Text: "ability_id"; Padding: (Bottom: 8); }
                Label #Ability1Summary { Style: @BodyStyle; Text: "Ability summary."; Padding: (Bottom: 6); }
                Label #Ability1Meta { Style: @MetaStyle; Text: "Cost 0 | Cooldown 0s | Ready in 0s"; }
              }

              @AbilityCard #AbilityCard2 {
                Label #Ability2Name { Style: @CardTitleStyle; Text: "Ability Two"; }
                Label #Ability2Id { Style: @MutedStyle; Text: "ability_id"; Padding: (Bottom: 8); }
                Label #Ability2Summary { Style: @BodyStyle; Text: "Ability summary."; Padding: (Bottom: 6); }
                Label #Ability2Meta { Style: @MetaStyle; Text: "Cost 0 | Cooldown 0s | Ready in 0s"; }
              }

              @AbilityCard #AbilityCard3 {
                Label #Ability3Name { Style: @CardTitleStyle; Text: "Ability Three"; }
                Label #Ability3Id { Style: @MutedStyle; Text: "ability_id"; Padding: (Bottom: 8); }
                Label #Ability3Summary { Style: @BodyStyle; Text: "Ability summary."; Padding: (Bottom: 6); }
                Label #Ability3Meta { Style: @MetaStyle; Text: "Cost 0 | Cooldown 0s | Ready in 0s"; }
              }
            }
          }

          @SectionPanel #PerksPanel {
            Visible: false;

            @LargeCard #PerksSummaryCard {
              Label { Style: @CardTitleStyle; Text: "Perk Rules"; }
              Group { Anchor: (Height: 10); }
              Label #PerksDesignValue { Style: @BodyStyle; Text: "Perks are passive modifiers, triggers, and synergies."; Padding: (Bottom: 10); }

              Group {
                LayoutMode: Left;

                @SmallCard #PerksUnlockedCard {
                  @Width = 130;
                  Label { Style: @BadgeLabelStyle; Text: "Unlocked"; }
                  Label #PerksUnlockedValue { Style: @BadgeValueStyle; Text: "0 / 20"; }
                }

                Group { Anchor: (Width: 10); }

                @SmallCard #PerksOwnedCard {
                  @Width = 150;
                  Label { Style: @BadgeLabelStyle; Text: "Owned"; }
                  Label #PerksOwnedValue { Style: @BadgeValueStyle; Text: "0 / 60"; }
                }

                Group { Anchor: (Width: 10); }

                @SmallCard #PerksSynergyCard {
                  @Width = 140;
                  Label { Style: @BadgeLabelStyle; Text: "Synergies"; }
                  Label #PerksSynergyValue { Style: @BadgeValueStyle; Text: "0"; }
                }
              }

              Label { Style: @KeyStyle; Text: "Status"; Padding: (Top: 14); }
              Label #PerksStatusValue { Style: @ValueStyle; Text: "Choose a class first to begin your build."; }
              Label { Style: @KeyStyle; Text: "Queued"; Padding: (Top: 12); }
              Label #PerksSelectionValue { Style: @BodyStyle; Text: "Queued Choices: none"; }
            }

            Group { Anchor: (Height: 14); }

            Group #PerksControls {
              LayoutMode: Left;
              @WideActionButton #PerksConfirmButton { Text: "Confirm 3 Picks"; }
              Group { Anchor: (Width: 10); }
              @WideActionButton #PerksClearButton { Text: "Clear Queue"; }
            }

            Group { Anchor: (Height: 14); }

            Group #PerksChoicesContainer {
              LayoutMode: Top;

              @PerkRow #PerkRow1 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk1Index { Style: @CardTitleStyle; Text: "[1]"; }
                  Label #Perk1Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk1Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton1 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow2 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk2Index { Style: @CardTitleStyle; Text: "[2]"; }
                  Label #Perk2Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk2Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton2 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow3 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk3Index { Style: @CardTitleStyle; Text: "[3]"; }
                  Label #Perk3Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk3Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton3 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow4 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk4Index { Style: @CardTitleStyle; Text: "[4]"; }
                  Label #Perk4Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk4Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton4 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow5 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk5Index { Style: @CardTitleStyle; Text: "[5]"; }
                  Label #Perk5Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk5Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton5 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow6 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk6Index { Style: @CardTitleStyle; Text: "[6]"; }
                  Label #Perk6Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk6Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton6 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow7 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk7Index { Style: @CardTitleStyle; Text: "[7]"; }
                  Label #Perk7Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk7Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton7 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow8 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk8Index { Style: @CardTitleStyle; Text: "[8]"; }
                  Label #Perk8Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk8Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton8 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow9 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk9Index { Style: @CardTitleStyle; Text: "[9]"; }
                  Label #Perk9Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk9Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton9 { Text: "Queue"; }
              }

              Group { Anchor: (Height: 8); }

              @PerkRow #PerkRow10 {
                Group {
                  FlexWeight: 1;
                  LayoutMode: Top;
                  Label #Perk10Index { Style: @CardTitleStyle; Text: "[10]"; }
                  Label #Perk10Name { Style: @ValueStyle; Text: "Perk Name"; Padding: (Top: 2, Bottom: 4); }
                  Label #Perk10Desc { Style: @BodyStyle; Text: "Perk description."; }
                }
                Group { Anchor: (Width: 12); }
                @WideActionButton #PerkButton10 { Text: "Queue"; }
              }
            }

            Label #PerksEmpty {
              Style: @MutedStyle;
              Text: "No pending perk choices right now. Reach the next milestone to open another tier.";
              Padding: (Top: 12);
            }
          }

          @SectionPanel #ResourcesPanel {
            Visible: false;

            @LargeCard #ResourcesCard {
              Label { Style: @CardTitleStyle; Text: "Current Resource"; }
              Group { Anchor: (Height: 12); }
              Label #ResourcesCurrentValue { Style: @ValueStyle; Text: "No class resource yet."; Padding: (Bottom: 12); }
              Label { Style: @KeyStyle; Text: "Rule"; }
              Label #ResourcesRuleValue { Style: @BodyStyle; Text: "Choose a class to unlock its resource system."; Padding: (Bottom: 12); }
              Label { Style: @KeyStyle; Text: "Practical Buffs"; }
              Label #ResourcesPracticalValue { Style: @BodyStyle; Text: "Practical perks can improve sustain, movement, gathering, healing, and survival while playing Hytale normally."; }
            }
          }

          @SectionPanel #CodexPanel {
            Visible: false;

            @LargeCard #CodexCard {
              Label { Style: @CardTitleStyle; Text: "System Notes"; }
              Group { Anchor: (Height: 12); }
              Label { Style: @KeyStyle; Text: "Flow"; }
              Label #CodexFlowValue { Style: @BodyStyle; Text: "Class -> Style -> 3 abilities -> Level milestones -> Perk tiers -> Synergies"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Reactions"; }
              Label #CodexReactionsValue { Style: @BodyStyle; Text: "Elemental reactions and status marks will live here as the combat execution layer grows."; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Scaling"; }
              Label #CodexScalingValue { Style: @BodyStyle; Text: "Enemies scale with progression and may gain elite titles based on zone and conditions."; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Current Focus"; }
              Label #CodexFocusValue { Style: @BodyStyle; Text: "Current focus: spellbook UI, passive perk execution, and stronger ability runtime hooks."; }
            }
          }

          @SectionPanel #JournalPanel {
            Visible: false;

            @LargeCard #JournalCard {
              Label { Style: @CardTitleStyle; Text: "Story Ledger"; }
              Group { Anchor: (Height: 12); }
              Label #JournalStatusValue { Style: @BodyStyle; Text: "Story pages are reserved for Mentees lore, discoveries, factions, and future quests."; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Current Path"; }
              Label #JournalPathValue { Style: @ValueStyle; Text: "Current Path: Unchosen / Unchosen / Unchosen"; Padding: (Bottom: 10); }
              Label { Style: @KeyStyle; Text: "Future Chapters"; }
              Label #JournalFutureValue { Style: @BodyStyle; Text: "Planned chapters: origin notes, class-specific story beats, race lore, and a discovery log."; }
            }
          }
        }
      }
    }
  }
}
