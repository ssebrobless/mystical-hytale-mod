{
  "xp_scaling_formula": {
    "description": "XP scales with mob level",
    "formula": "actual_xp = base_xp * (1 + mob_level * 0.1)",
    "example_level_1": "50 * (1 + 1 * 0.1) = 55 XP",
    "example_level_10": "50 * (1 + 10 * 0.1) = 100 XP",
    "example_level_50": "50 * (1 + 50 * 0.1) = 300 XP",
    "example_level_100": "50 * (1 + 100 * 0.1) = 550 XP"
  },
  "mob_categories": {
    "passive": {
      "description": "Non-aggressive creatures that flee from players",
      "base_xp_range": [5, 10],
      "examples": ["sheep", "chicken", "rabbit", "cow", "pig", "deer"]
    },
    "neutral": {
      "description": "Creatures that only attack when provoked",
      "base_xp_range": [15, 25],
      "examples": ["wolf", "bear", "boar", "spider", "bee_swarm"]
    },
    "hostile": {
      "description": "Aggressive creatures that attack on sight",
      "base_xp_range": [50, 100],
      "examples": ["zombie", "skeleton", "goblin", "trork", "kweebec_hostile"]
    },
    "elite": {
      "description": "Stronger variants of regular hostile mobs",
      "base_xp_range": [150, 300],
      "spawn_rate": "rare",
      "examples": ["elite_zombie", "goblin_chieftain", "armored_skeleton"]
    },
    "mini_boss": {
