  "xp_penalties": {
    "level_difference_penalty": {
      "description": "XP penalty when mob is much lower level than player",
      "formula": "penalty = max(0, (player_level - mob_level - 10) * 0.05)",
      "max_penalty": 0.90,
      "example": "Player level 50 killing level 30 mob: penalty = (50-30-10)*0.05 = 0.50 (50% XP reduction)"
    },
    "repeat_kill_penalty": {
      "description": "XP reduction for killing same mob type repeatedly in short time",
      "threshold": 10,
      "penalty_per_kill_over_threshold": 0.05,
      "max_penalty": 0.50,
      "reset_time_minutes": 30
    }
  },
